---
import Layout from '../layouts/Layout.astro';
import { GraduationCap, Award, Server, FileText, Download } from 'lucide-react';
---

<Layout title="About - Brent Zey">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24 space-y-24 animate-fade-in">
    
    <section class="flex flex-col md:flex-row items-center gap-12">
      <div class="flex-1 space-y-6">
        <h1 class="text-5xl md:text-6xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-cyan to-synth-blue synth-text-glow">About Me</h1>
        <p class="text-xl md:text-2xl text-[var(--text-secondary)] leading-relaxed font-light">
          I’m a software engineer in healthcare technology, formerly fintech, and I build full stack, native, and mobile applications.
        </p>
      </div>
      <div class="relative group">
        <div class="absolute -inset-1 bg-gradient-to-r from-synth-cyan to-synth-blue rounded-3xl blur opacity-25 group-hover:opacity-50 transition duration-1000" aria-hidden="true"></div>
        <img 
          src="/profile.png" 
          alt="Portrait of Brent Zey" 
          class="relative w-48 h-48 md:w-64 md:h-64 rounded-3xl border border-[var(--border-color)] object-cover shadow-2xl grayscale hover:grayscale-0 transition-all duration-500"
        />
      </div>
    </section>

    {/* Resume Section */}
    <section class="space-y-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="space-y-2">
          <h2 class="text-3xl font-bold uppercase tracking-widest text-[var(--text-primary)]">Resume Highlights</h2>
          <div class="w-24 h-1 bg-gradient-to-r from-synth-cyan via-synth-periwinkle to-synth-pink rounded-full" aria-hidden="true"></div>
        </div>
        <a 
          href="/resume.pdf" 
          target="_blank" 
          class="inline-flex items-center gap-2 px-6 py-3 rounded-2xl bg-synth-cyan/10 text-synth-cyan hover:bg-synth-cyan hover:text-black transition-all font-bold uppercase tracking-widest text-sm border border-synth-cyan/20 group"
          aria-label="Download Brent Zey's Resume PDF (2025)"
        >
          <Download class="w-4 h-4 group-hover:animate-bounce" aria-hidden="true" />
          Download PDF (2025)
        </a>
      </div>
      
      <div class="relative group p-8 md:p-12 rounded-[2.5rem] bg-[var(--card-bg)] border border-[var(--border-color)] shadow-xl overflow-hidden">
        <div class="absolute top-0 right-0 p-8 opacity-5" aria-hidden="true">
          <FileText class="w-32 h-32" />
        </div>
        
        <div class="grid md:grid-cols-2 gap-12 relative z-10">
          <div class="space-y-8">
            <div>
              <h3 class="text-xs font-black uppercase tracking-[0.3em] text-synth-cyan mb-4">Core Expertise</h3>
              <ul class="space-y-3 text-[var(--text-secondary)]">
                <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 rounded-full bg-synth-cyan mt-2" aria-hidden="true"></span> Enterprise Healthcare Architectures</li>
                <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 rounded-full bg-synth-cyan mt-2" aria-hidden="true"></span> High-Availability SAAS & Web Services</li>
                <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 rounded-full bg-synth-cyan mt-2" aria-hidden="true"></span> Full Stack, Native & Mobile Development</li>
                <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 rounded-full bg-synth-cyan mt-2" aria-hidden="true"></span> Quantitative Economic Analysis</li>
              </ul>
            </div>
            
            <div>
              <h3 class="text-xs font-black uppercase tracking-[0.3em] text-synth-pink mb-4">Technical Stack</h3>
              <div class="flex flex-wrap gap-2">
                {["Kotlin", "Java", "TypeScript", "Scala", "Spring Boot", "Quarkus", "KMP", "PostgreSQL", "React", "Astro", "Docker"].map(tech => (
                  <span class="px-3 py-1 rounded-lg bg-[var(--nav-bg)] border border-[var(--border-color)] text-xs font-mono text-[var(--text-secondary)]">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
          
          <div class="space-y-8">
            <div>
              <h3 class="text-xs font-black uppercase tracking-[0.3em] text-synth-purple mb-4">Experience Highlights</h3>
              <div class="space-y-6">
                <div class="relative pl-6 border-l border-[var(--border-color)]">
                  <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-synth-purple"></div>
                  <h4 class="font-bold text-[var(--text-primary)]">Enterprise Healthcare Engineer</h4>
                  <p class="text-xs text-[var(--text-secondary)] uppercase tracking-wider mb-2">Government & Private Sector focus</p>
                  <p class="text-sm text-[var(--text-secondary)]">Architecting robust, compliant systems for high-stakes healthcare environments.</p>
                </div>
                <div class="relative pl-6 border-l border-[var(--border-color)]">
                  <div class="absolute -left-1.5 top-1.5 w-3 h-3 rounded-full bg-synth-periwinkle"></div>
                  <h4 class="font-bold text-[var(--text-primary)]">Software Engineer (Fintech)</h4>
                  <p class="text-xs text-[var(--text-secondary)] uppercase tracking-wider mb-2">Financial Services</p>
                  <p class="text-sm text-[var(--text-secondary)]">Built secure, performant applications in the fintech space.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Professional Role Section */}
    <section class="space-y-8">
      <div class="space-y-2">
        <h2 class="text-3xl font-bold uppercase tracking-widest text-[var(--text-primary)]">Professional Role</h2>
        <div class="w-24 h-1 bg-gradient-to-r from-synth-cyan to-synth-blue rounded-full" aria-hidden="true"></div>
      </div>
      
      <div class="p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-cyan/50 transition-colors shadow-lg">
        <Server class="w-12 h-12 text-synth-cyan mb-6" aria-hidden="true" />
        <h3 class="text-2xl font-bold mb-4">Enterprise Healthcare Engineer</h3>
        <p class="text-[var(--text-secondary)] leading-relaxed text-lg">
          By day, I specialize in building robust, compliant SAAS and web service architectures for both Government and private sectors in the healthcare industry. My focus is on scalability, security, and high-availability systems.
        </p>
      </div>
    </section>

    {/* Background & Education Section */}
    <section class="space-y-8">
      <div class="space-y-2">
        <h2 class="text-3xl font-bold uppercase tracking-widest text-[var(--text-primary)]">Academic Foundation</h2>
        <div class="w-24 h-1 bg-gradient-to-r from-synth-pink to-synth-purple rounded-full" aria-hidden="true"></div>
      </div>
      
      <div class="space-y-8">
        <p class="text-lg text-[var(--text-secondary)] leading-relaxed italic border-l-4 border-synth-pink pl-6">
          "A multi-disciplinary approach to engineering, rooted in quantitative analysis and humanistic studies."
        </p>
        
        <div class="grid md:grid-cols-2 gap-8 pt-4">
          <div class="p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-pink/50 transition-colors">
            <div class="inline-flex p-3 rounded-2xl bg-synth-pink/10 text-synth-pink mb-4" aria-hidden="true">
              <GraduationCap class="w-8 h-8" />
            </div>
            <h4 class="text-xl font-bold mb-2">University of Kansas</h4>
            <p class="text-[var(--text-secondary)] mb-4">Master of Arts in Economics</p>
            <p class="text-xs text-synth-pink uppercase tracking-widest font-bold">PhD-Level Coursework Training</p>
          </div>
          
          <div class="p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-purple/50 transition-colors">
            <div class="inline-flex p-3 rounded-2xl bg-synth-purple/10 text-synth-purple mb-4" aria-hidden="true">
              <Award class="w-8 h-8" />
            </div>
            <h4 class="text-xl font-bold mb-2">Bachelor of Science</h4>
            <p class="text-[var(--text-secondary)] mb-4">Economics & French</p>
            <p class="text-xs text-synth-purple uppercase tracking-widest font-bold">Math-Statistics Emphasis</p>
          </div>
        </div>
        
        <div class="pt-8 flex flex-wrap gap-3">
          {["Quantitative Economics", "Econometrics", "Economic Research", "Math", "Statistics", "Probability", "French Literature", "Society Studies"].map(skill => (
            <span class="px-4 py-2 rounded-full bg-[var(--nav-bg)] border border-[var(--border-color)] text-[var(--text-secondary)] text-sm font-medium hover:border-synth-cyan hover:text-synth-cyan transition-colors cursor-default">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </section>

  </div>
</Layout>
