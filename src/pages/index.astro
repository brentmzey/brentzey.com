---
import Layout from '../layouts/Layout.astro';
import { Github, Mail, Globe, MonitorSmartphone, Server, Database, Coffee, Camera, Plane, Code2, ExternalLink, GraduationCap, Award } from 'lucide-react';

const projects = [
  {
    title: "Sanctuary Stream",
    description: "An open-source, free application designed for parishes to implement high-quality liturgical ministry streaming while following best practices.",
    link: "https://github.com/brentmzey/sanctuary-stream",
    tags: ["Open Source", "Kotlin", "Streaming"]
  },
  {
    title: "Functional Utils",
    description: "Bringing functional programming features (similar to Scala or Arrow) to raw Java and Kotlin Multiplatform (KMP).",
    link: "https://github.com/brentmzey/functional-utils",
    tags: ["KMP", "Java", "Functional Programming"]
  },
  {
    title: "Local DB Stack",
    description: "A collection of shell utilities for managing local database stacks efficiently during development.",
    link: "https://github.com/brentmzey/local-db-stack",
    tags: ["DevOps", "Shell", "Databases"]
  }
];

const customSites = [
  {
    title: "Jenny Lungo",
    description: "Professional site for a master fade expert and hairstyle specialist in Chicago's Loop.",
    link: "https://jennylungo.hair/",
    type: "Business / Portfolio"
  },
  {
    title: "Dr. Craig A. Ford, Jr.",
    description: "Academic and professional site for a scholar and professor at Emory University.",
    link: "https://craigford.net/",
    type: "Academic / Personal"
  },
  {
    title: "Andrew Ouma",
    description: "Custom portfolio site for professional showcasing.",
    link: "https://andrew-ouma.netlify.app/",
    type: "Portfolio"
  },
  {
    title: "Hops-n-Scotch",
    description: "A specialized project focused on craft beer and spirits curation.",
    link: "https://hops-n-scotch.netlify.app/",
    type: "Web App"
  }
];
---

<Layout title="Brent Zey - Software Engineer">
  <main class="max-w-4xl mx-auto px-6 py-16 md:py-24 space-y-32">
    
    {/* Hero Section */}
    <section class="space-y-8 animate-fade-in">
      <div class="space-y-4">
        <span class="inline-block px-3 py-1 text-xs font-bold tracking-widest text-cyan-400 uppercase bg-cyan-400/10 rounded-full">
          Healthcare Web Services Engineer
        </span>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white leading-tight">
          Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Brent Zey</span>
        </h1>
      </div>
      <p class="text-xl md:text-2xl text-slate-300 leading-relaxed font-light max-w-2xl">
        I’m a software engineer in healthcare technology, formerly fintech, and I build full stack, native, and mobile applications through freelance, side projects, and open source work.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <a href="https://github.com/brentmzey" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-slate-800 hover:bg-slate-700 text-white font-medium transition-all border border-slate-700 hover:border-slate-600 hover:scale-[1.02]">
          <Github class="w-5 h-5" />
          GitHub
        </a>
        <a href="mailto:contact@brentzey.com" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-cyan-600 hover:bg-cyan-500 text-white font-medium transition-all shadow-[0_0_20px_rgba(8,145,178,0.3)] hover:scale-[1.02]">
          <Mail class="w-5 h-5" />
          Get in Touch
        </a>
      </div>
    </section>

    {/* Featured Projects & Open Source */}
    <section class="space-y-12">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div class="space-y-2">
          <h2 class="text-3xl md:text-4xl font-bold text-white">Open Source & Projects</h2>
          <div class="w-24 h-1 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full"></div>
        </div>
        <p class="text-slate-400 max-w-xs text-sm">
          A selection of my contributions to the open source community and personal technical explorations.
        </p>
      </div>
      
      <div class="grid md:grid-cols-3 gap-6">
        {projects.map(project => (
          <a href={project.link} target="_blank" rel="noopener noreferrer" class="group p-6 rounded-2xl bg-slate-800/40 border border-slate-700/50 hover:border-cyan-500/50 hover:bg-slate-800/60 transition-all flex flex-col h-full">
            <div class="flex justify-between items-start mb-4">
              <Code2 class="w-6 h-6 text-cyan-400" />
              <ExternalLink class="w-4 h-4 text-slate-500 group-hover:text-cyan-400 transition-colors" />
            </div>
            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-cyan-400 transition-colors">{project.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-grow">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="text-[10px] font-bold uppercase tracking-wider text-slate-500 bg-slate-900/50 px-2 py-1 rounded">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    {/* Custom Built Sites */}
    <section class="space-y-12">
      <div class="space-y-2">
        <h2 class="text-3xl md:text-4xl font-bold text-white">Custom Built Solutions</h2>
        <div class="w-24 h-1 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full"></div>
      </div>
      
      <div class="grid md:grid-cols-2 gap-6">
        {customSites.map(site => (
          <a href={site.link} target="_blank" rel="noopener noreferrer" class="group flex items-center p-6 rounded-2xl bg-slate-800/30 border border-slate-700/30 hover:bg-slate-800/50 transition-all">
            <div class="p-4 rounded-xl bg-slate-900/50 text-cyan-400 mr-6 group-hover:scale-110 transition-transform">
              <MonitorSmartphone class="w-6 h-6" />
            </div>
            <div class="flex-grow">
              <div class="flex items-center gap-2 mb-1">
                <h3 class="text-lg font-bold text-white group-hover:text-cyan-400 transition-colors">{site.title}</h3>
                <span class="text-[10px] text-cyan-500 font-bold uppercase">{site.type}</span>
              </div>
              <p class="text-slate-400 text-sm">{site.description}</p>
            </div>
            <ExternalLink class="w-4 h-4 text-slate-600 group-hover:text-cyan-400 ml-4" />
          </a>
        ))}
      </div>
    </section>

    {/* Services & Role Section */}
    <section class="grid md:grid-cols-2 gap-12">
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-white">Professional Role</h2>
        <div class="w-20 h-1 bg-cyan-500 rounded-full"></div>
        <div class="p-8 rounded-3xl bg-gradient-to-br from-slate-800/50 to-transparent border border-slate-700/50">
          <Server class="w-10 h-10 text-cyan-400 mb-6" />
          <h3 class="text-xl font-bold text-white mb-4">Enterprise Healthcare Engineer</h3>
          <p class="text-slate-300 leading-relaxed">
            By day, I specialize in building robust, compliant SAAS and web service architectures for both Government and private sectors in the healthcare industry. My focus is on scalability, security, and high-availability systems.
          </p>
        </div>
      </div>
      
      <div class="space-y-6">
        <h2 class="text-3xl font-bold text-white">Development Services</h2>
        <div class="w-20 h-1 bg-cyan-500 rounded-full"></div>
        <div class="p-8 rounded-3xl bg-gradient-to-br from-slate-800/50 to-transparent border border-slate-700/50">
          <MonitorSmartphone class="w-10 h-10 text-cyan-400 mb-6" />
          <h3 class="text-xl font-bold text-white mb-4">Full Stack & Native Apps</h3>
          <p class="text-slate-300 leading-relaxed">
            I help clients turn ideas into reality through custom-built websites, complex web applications, and native mobile development. From initial architecture to deployment, I ensure high performance and modern standards.
          </p>
        </div>
      </div>
    </section>

    {/* Background & Education Section */}
    <section class="space-y-12">
      <div class="space-y-2">
        <h2 class="text-3xl md:text-4xl font-bold text-white text-center">Academic Foundation</h2>
        <div class="w-24 h-1 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full mx-auto"></div>
      </div>
      
      <div class="max-w-3xl mx-auto space-y-8 text-center">
        <p class="text-lg text-slate-400 leading-relaxed italic">
          "A multi-disciplinary approach to engineering, rooted in quantitative analysis and humanistic studies."
        </p>
        
        <div class="grid md:grid-cols-2 gap-8 pt-8">
          <div class="space-y-4">
            <div class="inline-flex p-3 rounded-2xl bg-cyan-900/20 text-cyan-400 mb-2">
              <GraduationCap class="w-8 h-8" />
            </div>
            <h4 class="text-xl font-bold text-white">University of Kansas</h4>
            <p class="text-slate-400">Master of Arts in Economics</p>
            <p class="text-xs text-slate-500 uppercase tracking-widest font-bold">PhD-Level Coursework Training</p>
          </div>
          
          <div class="space-y-4">
            <div class="inline-flex p-3 rounded-2xl bg-cyan-900/20 text-cyan-400 mb-2">
              <Award class="w-8 h-8" />
            </div>
            <h4 class="text-xl font-bold text-white">Bachelor of Science</h4>
            <p class="text-slate-400">Economics & French</p>
            <p class="text-xs text-slate-500 uppercase tracking-widest font-bold">Math-Statistics Emphasis</p>
          </div>
        </div>
        
        <div class="pt-8 flex flex-wrap justify-center gap-3">
          {["Quantitative Economics", "Econometrics", "Economic Research", "Math", "Statistics", "Probability", "French Literature", "Society Studies"].map(skill => (
            <span class="px-4 py-2 rounded-full bg-slate-800/50 border border-slate-700/50 text-slate-300 text-sm font-medium">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </section>

    {/* Photography & Interests Section */}
    <section class="space-y-12 bg-slate-800/20 -mx-6 px-6 py-24 rounded-[3rem] border border-slate-700/30">
      <div class="text-center space-y-4 max-w-2xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white">Photography Selects</h2>
        <p class="text-slate-400">A curated portfolio of my favorite shots from 2019 to 2025, exploring landscapes, street photography, and daily life.</p>
        <a href="https://photos.app.goo.gl/u2aaK1DFGrDbkwxx8" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-cyan-400 font-bold hover:underline group">
          View Google Photos Album
          <ExternalLink class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
        </a>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="group relative aspect-square rounded-3xl overflow-hidden bg-slate-900 border border-slate-700/50 hover:scale-[1.05] transition-transform duration-500">
          <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center space-y-4 opacity-100 group-hover:opacity-0 transition-opacity">
            <Coffee class="w-10 h-10 text-amber-500" />
            <span class="font-bold text-white uppercase tracking-tighter">Craft Coffee</span>
          </div>
        </div>
        
        <div class="group relative aspect-square rounded-3xl overflow-hidden bg-slate-900 border border-slate-700/50 hover:scale-[1.05] transition-transform duration-500">
          <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center space-y-4 opacity-100 group-hover:opacity-0 transition-opacity">
            <Camera class="w-10 h-10 text-emerald-400" />
            <span class="font-bold text-white uppercase tracking-tighter">Photography</span>
          </div>
        </div>
        
        <div class="group relative aspect-square rounded-3xl overflow-hidden bg-slate-900 border border-slate-700/50 hover:scale-[1.05] transition-transform duration-500">
          <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center space-y-4 opacity-100 group-hover:opacity-0 transition-opacity">
            <Plane class="w-10 h-10 text-sky-400" />
            <span class="font-bold text-white uppercase tracking-tighter">Travel</span>
          </div>
        </div>
        
        <div class="group relative aspect-square rounded-3xl overflow-hidden bg-slate-900 border border-slate-700/50 hover:scale-[1.05] transition-transform duration-500">
          <div class="absolute inset-0 flex flex-col items-center justify-center p-6 text-center space-y-4 opacity-100 group-hover:opacity-0 transition-opacity">
            <Code2 class="w-10 h-10 text-purple-400" />
            <span class="font-bold text-white uppercase tracking-tighter">Software</span>
          </div>
        </div>
      </div>
    </section>

  </main>
  
  <footer class="border-t border-slate-800 mt-12 py-12 text-center space-y-4">
    <div class="flex justify-center gap-6">
      <a href="https://github.com/brentmzey" class="text-slate-500 hover:text-white transition-colors"><Github /></a>
      <a href="mailto:contact@brentzey.com" class="text-slate-500 hover:text-white transition-colors"><Mail /></a>
    </div>
    <p class="text-slate-500 text-sm">&copy; {new Date().getFullYear()} Brent Zey. All rights reserved.</p>
  </footer>
</Layout>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
</style>
