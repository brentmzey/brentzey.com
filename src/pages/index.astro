---
import Layout from '../layouts/Layout.astro';
import { Github, Mail, MonitorSmartphone, Code2, Coffee, Camera, ExternalLink, User } from 'lucide-react';
---

<Layout title="Brent Zey - Software Engineer">
  <div class="max-w-4xl mx-auto px-6 py-20 md:py-32 space-y-32">
    
    {/* Hero Section */}
    <section class="space-y-8 animate-fade-in text-center flex flex-col items-center">
      <div class="relative group">
        <div class="absolute -inset-1.5 bg-gradient-to-r from-synth-cyan via-synth-periwinkle to-synth-pink rounded-full blur opacity-40 group-hover:opacity-100 transition duration-1000 group-hover:duration-200 animate-pulse" aria-hidden="true"></div>
        <img 
          src="/profile.png" 
          alt="Portrait of Brent Zey, Software Engineer" 
          class="relative w-32 h-32 md:w-48 md:h-48 rounded-full border-2 border-[var(--border-color)] object-cover bg-[var(--card-bg)] shadow-2xl"
        />
      </div>

      <div class="relative inline-block animate-float">
        <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-cyan via-synth-purple to-synth-pink synth-text-glow-strong leading-tight pb-2 uppercase relative z-10">
          Brent Zey
        </h1>
        <div class="neon-glow-container" aria-hidden="true">
          <div class="neon-glow-rotating"></div>
          <div class="neon-glow-rotating-alt"></div>
        </div>
        <div class="absolute -inset-12 bg-gradient-to-r from-synth-cyan/15 via-synth-purple/15 to-synth-pink/15 blur-3xl -z-10 rounded-full animate-pulse" aria-hidden="true"></div>
      </div>
      
      <div class="relative group">
        <p class="text-xl md:text-3xl text-[var(--text-secondary)] font-medium max-w-2xl leading-relaxed relative z-10">
          Building scalable <span class="text-synth-cyan font-bold">healthcare</span> systems, contributing to <span class="text-synth-pink font-bold">open source</span>, and exploring <span class="text-synth-purple font-bold">creative development</span>.
        </p>
        <div class="neon-glow-container" aria-hidden="true">
          <div class="neon-glow-rotating transition-opacity"></div>
          <div class="neon-glow-rotating-alt transition-opacity"></div>
        </div>
        <div class="absolute -inset-10 bg-gradient-to-r from-synth-cyan/10 via-synth-purple/10 to-synth-pink/10 blur-3xl -z-10 rounded-full animate-pulse" aria-hidden="true"></div>
      </div>

      <div class="flex flex-wrap justify-center gap-6 pt-8">
        <a href="/work" class="group relative px-8 py-4 rounded-xl bg-[var(--card-bg)] border border-synth-pink/50 hover:border-synth-pink text-[var(--text-primary)] font-bold uppercase tracking-widest transition-all hover:synth-glow-pink overflow-hidden">
          <div class="absolute inset-0 bg-synth-pink/10 translate-y-full group-hover:translate-y-0 transition-transform" aria-hidden="true"></div>
          <span class="relative flex items-center gap-2"><Code2 class="w-5 h-5 text-synth-pink" aria-hidden="true"/> View Work</span>
        </a>
        <a href="mailto:brentmzey4795@gmail.com" class="group relative px-8 py-4 rounded-xl bg-[var(--card-bg)] border border-synth-cyan/50 hover:border-synth-cyan text-[var(--text-primary)] font-bold uppercase tracking-widest transition-all hover:synth-glow-cyan overflow-hidden">
          <div class="absolute inset-0 bg-synth-cyan/10 translate-y-full group-hover:translate-y-0 transition-transform" aria-hidden="true"></div>
          <span class="relative flex items-center gap-2"><Mail class="w-5 h-5 text-synth-cyan" aria-hidden="true"/> Connect</span>
        </a>
      </div>
    </section>

    {/* Navigation Grid */}
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
      <a href="/about" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-cyan/50 hover:synth-glow-cyan transition-all flex flex-col items-center text-center space-y-4" aria-label="Learn more about Brent Zey">
        <div class="p-4 rounded-2xl bg-synth-cyan/10 text-synth-cyan group-hover:scale-110 transition-transform" aria-hidden="true">
          <User class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">About Me</h2>
        <p class="text-[var(--text-secondary)]">From quantitative economics to healthcare software engineering. Discover my journey and academic foundation.</p>
      </a>

      <a href="/work" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-pink/50 hover:synth-glow-pink transition-all flex flex-col items-center text-center space-y-4" aria-label="View Brent Zey's work and projects">
        <div class="p-4 rounded-2xl bg-synth-pink/10 text-synth-pink group-hover:scale-110 transition-transform" aria-hidden="true">
          <Code2 class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">Work & Projects</h2>
        <p class="text-[var(--text-secondary)]">A deep dive into my professional healthcare architecture, open-source contributions, and custom web solutions.</p>
      </a>

      <a href="/gallery" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-purple/50 transition-all flex flex-col items-center text-center space-y-4 hover:shadow-[0_0_15px_rgba(157,0,255,0.4)]" aria-label="View Brent Zey's photography gallery">
        <div class="p-4 rounded-2xl bg-synth-purple/10 text-synth-purple group-hover:scale-110 transition-transform" aria-hidden="true">
          <Camera class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">Gallery</h2>
        <p class="text-[var(--text-secondary)]">Visual storytelling through photography: exploring urban landscapes, neon nights, and daylight moments.</p>
      </a>

      <a href="/interests" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-periwinkle/50 transition-all flex flex-col items-center text-center space-y-4 hover:shadow-[0_0_15px_rgba(164,154,255,0.4)]" aria-label="Learn about Brent Zey's interests">
        <div class="p-4 rounded-2xl bg-synth-periwinkle/10 text-synth-periwinkle group-hover:scale-110 transition-transform" aria-hidden="true">
          <MonitorSmartphone class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">Interests</h2>
        <p class="text-[var(--text-secondary)]">Life beyond the terminal: diving into specialty coffee, fitness, music, and the pursuits that keep me inspired.</p>
      </a>
    </section>

  </div>
</Layout>
