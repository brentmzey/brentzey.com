---
import Layout from '../layouts/Layout.astro';
import { Github, Mail, MonitorSmartphone, Code2, Coffee, Camera, ExternalLink, User } from 'lucide-react';
---

<Layout title="Brent Zey - Synthwave Hub">
  <div class="max-w-4xl mx-auto px-6 py-20 md:py-32 space-y-32">
    
    {/* Hero Section */}
    <section class="space-y-8 animate-fade-in text-center flex flex-col items-center">
      <div class="relative inline-block animate-float">
        <h1 class="text-6xl md:text-8xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-synth-cyan via-synth-periwinkle to-synth-pink synth-text-glow leading-tight pb-2 uppercase">
          Brent Zey
        </h1>
        <div class="absolute -inset-4 bg-synth-cyan/10 blur-3xl -z-10 rounded-full"></div>
      </div>
      
      <p class="text-xl md:text-3xl text-[var(--text-secondary)] font-medium max-w-2xl leading-relaxed">
        Engineering the future with a <span class="text-synth-cyan font-bold">neon</span> edge.
      </p>

      <div class="flex flex-wrap justify-center gap-6 pt-8">
        <a href="/work" class="group relative px-8 py-4 rounded-xl bg-[var(--card-bg)] border border-synth-pink/50 hover:border-synth-pink text-[var(--text-primary)] font-bold uppercase tracking-widest transition-all hover:synth-glow-pink overflow-hidden">
          <div class="absolute inset-0 bg-synth-pink/10 translate-y-full group-hover:translate-y-0 transition-transform"></div>
          <span class="relative flex items-center gap-2"><Code2 class="w-5 h-5 text-synth-pink"/> View Work</span>
        </a>
        <a href="mailto:contact@brentzey.com" class="group relative px-8 py-4 rounded-xl bg-[var(--card-bg)] border border-synth-cyan/50 hover:border-synth-cyan text-[var(--text-primary)] font-bold uppercase tracking-widest transition-all hover:synth-glow-cyan overflow-hidden">
          <div class="absolute inset-0 bg-synth-cyan/10 translate-y-full group-hover:translate-y-0 transition-transform"></div>
          <span class="relative flex items-center gap-2"><Mail class="w-5 h-5 text-synth-cyan"/> Connect</span>
        </a>
      </div>
    </section>

    {/* Navigation Grid */}
    <section class="grid grid-cols-1 md:grid-cols-2 gap-8 relative z-10">
      <a href="/about" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-cyan/50 hover:synth-glow-cyan transition-all flex flex-col items-center text-center space-y-4">
        <div class="p-4 rounded-2xl bg-synth-cyan/10 text-synth-cyan group-hover:scale-110 transition-transform">
          <User class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">About Me</h2>
        <p class="text-[var(--text-secondary)]">The mind behind the code. Academic foundation & professional journey.</p>
      </a>

      <a href="/work" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-pink/50 hover:synth-glow-pink transition-all flex flex-col items-center text-center space-y-4">
        <div class="p-4 rounded-2xl bg-synth-pink/10 text-synth-pink group-hover:scale-110 transition-transform">
          <Code2 class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">Work & Projects</h2>
        <p class="text-[var(--text-secondary)]">Healthcare engineering, open source, and full stack applications.</p>
      </a>

      <a href="/gallery" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-purple/50 transition-all flex flex-col items-center text-center space-y-4 hover:shadow-[0_0_15px_rgba(157,0,255,0.4)]">
        <div class="p-4 rounded-2xl bg-synth-purple/10 text-synth-purple group-hover:scale-110 transition-transform">
          <Camera class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">Gallery</h2>
        <p class="text-[var(--text-secondary)]">A curated portfolio of photography exploring neon nights and daylight.</p>
      </a>

      <a href="/interests" class="group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-periwinkle/50 transition-all flex flex-col items-center text-center space-y-4 hover:shadow-[0_0_15px_rgba(164,154,255,0.4)]">
        <div class="p-4 rounded-2xl bg-synth-periwinkle/10 text-synth-periwinkle group-hover:scale-110 transition-transform">
          <MonitorSmartphone class="w-8 h-8" />
        </div>
        <h2 class="text-2xl font-bold uppercase tracking-wider">Interests</h2>
        <p class="text-[var(--text-secondary)]">Diving into hobbies, side passions, and what keeps me exploring.</p>
      </a>
    </section>

  </div>
</Layout>
