---
import Layout from '../layouts/Layout.astro';
import { ExternalLink, Monitor, Smartphone, Globe, Code2 } from 'lucide-react';

const showcase = [
  {
    title: "Jenny Lungo",
    description: "A professional portfolio site for a master fade expert and hairstyle specialist based in Chicago's Loop. The site features high-resolution galleries and a seamless booking integration, designed to reflect the high-end, precise nature of her craft.",
    link: "https://jennylungo.hair/",
    type: "Business / Portfolio",
    tags: ["React", "Tailwind CSS", "Astro", "Framermotion"],
    image: "https://jennylungo.hair/og-image.jpg", // Using OG image if it exists, otherwise placeholder
    color: "from-synth-pink/20 to-synth-purple/20",
    accent: "text-synth-pink",
    border: "border-synth-pink/30"
  },
  {
    title: "Dr. Craig A. Ford, Jr.",
    description: "An academic and professional portfolio for a scholar and professor at Emory University. This project focused on creating a clean, authoritative digital presence to showcase academic research, publications, and professional engagements.",
    link: "https://craigford.net/",
    type: "Academic / Personal",
    tags: ["Typography Focus", "Astro", "Responsive Design"],
    image: "https://craigford.net/og-image.jpg",
    color: "from-synth-cyan/20 to-synth-blue/20",
    accent: "text-synth-cyan",
    border: "border-synth-cyan/30"
  },
  {
    title: "Andrew Ouma",
    description: "A custom-built portfolio site for a professional showcasing their diverse skillset and project history. Built with a focus on high performance and clean aesthetics to ensure a professional first impression.",
    link: "https://andrew-ouma.netlify.app/",
    type: "Portfolio",
    tags: ["Full Stack", "Minimalist", "Optimized Performance"],
    image: "https://andrew-ouma.netlify.app/profile.png",
    color: "from-synth-periwinkle/20 to-synth-purple/20",
    accent: "text-synth-periwinkle",
    border: "border-synth-periwinkle/30"
  },
  {
    title: "Hops-n-Scotch",
    description: "A specialized web application focused on the curation and discovery of craft beer and spirits. This project involved building a custom database-driven interface for enthusiasts to explore curated selections.",
    link: "https://hops-n-scotch.netlify.app/",
    type: "Web App / Specialty",
    tags: ["Data Visualization", "Curation", "Web App"],
    image: "https://hops-n-scotch.netlify.app/og-image.jpg",
    color: "from-synth-cyan/20 to-synth-pink/20",
    accent: "text-synth-cyan",
    border: "border-synth-cyan/30"
  }
];
---

<Layout title="Showcase - Client Projects - Brent Zey">
  <div class="max-w-6xl mx-auto px-6 py-12 md:py-24 space-y-24 animate-fade-in">
    
    <section class="max-w-4xl space-y-6">
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-cyan via-synth-purple to-synth-pink synth-text-glow-strong">
        Client Showcase
      </h1>
      <p class="text-xl md:text-2xl text-[var(--text-secondary)] leading-relaxed font-light">
        Custom digital experiences built for professionals, scholars, and businesses. Each site is a balance of <span class="text-synth-cyan font-bold">high-performance engineering</span> and <span class="text-synth-pink font-bold">bespoke design</span>.
      </p>
    </section>

    <div class="space-y-32">
      {showcase.map((site, index) => (
        <section class={`flex flex-col ${index % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-12 lg:gap-20 items-center reveal-on-scroll`}>
          
          {/* Browser Mockup */}
          <div class="flex-1 w-full relative group">
            <div class={`absolute -inset-4 bg-gradient-to-r ${site.color} blur-3xl rounded-[3rem] opacity-30 group-hover:opacity-60 transition-opacity duration-1000 -z-10`} aria-hidden="true"></div>
            
            <div class={`relative overflow-hidden rounded-2xl bg-[#020617] border ${site.border} shadow-2xl transition-all duration-500 group-hover:scale-[1.02] group-hover:shadow-[site.accent]/20`}>
              {/* Browser Header */}
              <div class="h-8 bg-slate-900 border-b border-white/5 flex items-center px-4 gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/50"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/50"></div>
                <div class="ml-4 flex-grow max-w-[200px] h-4 bg-white/5 rounded-full"></div>
              </div>
              
              {/* Visual Frame */}
              <div class="aspect-video relative bg-[#020617] overflow-hidden">
                {/* Fallback stylized visual if image fails */}
                <div class={`absolute inset-0 bg-gradient-to-br ${site.color} opacity-40 flex items-center justify-center`}>
                   <div class="flex flex-col items-center gap-4 text-white/20">
                     <Globe class="w-24 h-24" />
                     <span class="text-xs font-black uppercase tracking-[0.4em]">{site.title}</span>
                   </div>
                </div>
                
                {/* Site Screenshot - Assuming these will be added to public/screenshots/ later */}
                <img 
                  src={`/screenshots/${site.title.toLowerCase().replace(/\s+/g, '-')}.png`}
                  alt={`${site.title} website preview`}
                  class="absolute inset-0 w-full h-full object-cover object-top opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                  onerror="this.style.display='none'"
                />
              </div>
            </div>

            {/* Floating Device Badge */}
            <div class="absolute -bottom-6 -right-6 hidden md:flex items-center gap-3 p-4 rounded-2xl bg-[#020617]/80 backdrop-blur-xl border border-white/10 shadow-xl group-hover:translate-y-[-4px] transition-transform duration-500">
               <Monitor class="w-5 h-5 text-synth-cyan" />
               <Smartphone class="w-5 h-5 text-synth-pink" />
               <div class="w-px h-4 bg-white/10"></div>
               <span class="text-[10px] font-black uppercase tracking-widest text-[var(--text-secondary)]">Fully Responsive</span>
            </div>
          </div>

          {/* Project Details */}
          <div class="flex-1 space-y-8">
            <div class="space-y-4">
              <div class={`inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-white/5 border border-white/10 ${site.accent} text-[10px] font-black uppercase tracking-widest`}>
                {site.type}
              </div>
              <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-none">{site.title}</h2>
              <p class="text-[var(--text-secondary)] text-lg leading-relaxed">
                {site.description}
              </p>
            </div>

            <div class="flex flex-wrap gap-2">
              {site.tags.map(tag => (
                <span class="text-[10px] font-bold uppercase tracking-wider text-[var(--text-secondary)] bg-[var(--nav-bg)] border border-[var(--border-color)] px-3 py-1 rounded-lg">
                  {tag}
                </span>
              ))}
            </div>

            <div class="pt-4">
              <a 
                href={site.link} 
                target="_blank" 
                rel="noopener noreferrer" 
                class={`group relative inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-[var(--card-bg)] border border-white/10 hover:border-white/20 text-[var(--text-primary)] font-bold uppercase tracking-widest text-xs transition-all hover:scale-105 active:scale-95`}
              >
                <Globe class={`w-4 h-4 ${site.accent}`} />
                Visit Website
                <ExternalLink class="w-3.5 h-3.5 text-[var(--text-secondary)] group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
                <div class={`absolute inset-0 bg-white/5 opacity-0 group-hover:opacity-100 rounded-xl transition-opacity`}></div>
              </a>
            </div>
          </div>

        </section>
      ))}
    </div>

    {/* Contact CTA */}
    <section class="reveal-on-scroll relative group">
      <div class="absolute -inset-4 bg-gradient-to-r from-synth-cyan/10 via-synth-purple/10 to-synth-pink/10 blur-3xl rounded-[3rem] opacity-50 group-hover:opacity-100 transition-opacity -z-10" aria-hidden="true"></div>
      <div class="p-12 md:p-20 rounded-[3rem] bg-[var(--card-bg)] border border-[var(--border-color)] text-center space-y-8 overflow-hidden relative">
        <div class="absolute top-0 right-0 p-12 opacity-5 pointer-events-none" aria-hidden="true">
          <Code2 class="w-64 h-64" />
        </div>
        
        <h2 class="text-4xl md:text-6xl font-black uppercase tracking-tighter leading-tight relative z-10">
          Ready to build something <span class="text-transparent bg-clip-text bg-gradient-to-r from-synth-cyan to-synth-pink">exceptional?</span>
        </h2>
        <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto relative z-10">
          I partner with researchers, entrepreneurs, and creatives to translate their vision into high-performance web experiences.
        </p>
        <div class="pt-6 relative z-10">
          <a href="mailto:brentmzey4795@gmail.com" class="px-10 py-5 rounded-2xl bg-synth-cyan text-black font-black uppercase tracking-widest text-sm hover:synth-glow-cyan transition-all hover:-translate-y-1 active:scale-95 inline-block">
            Start a Project
          </a>
        </div>
      </div>
    </section>

  </div>
</Layout>
