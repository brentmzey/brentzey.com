---
import Layout from '../layouts/Layout.astro';
import { Camera, ExternalLink } from 'lucide-react';
import MasonryGallery from '../components/MasonryGallery.tsx';
import { getImage } from "astro:assets";

// Dynamically import all gallery images from assets
const images = import.meta.glob('../assets/gallery/*.{jpeg,jpg,png,webp}');
const imageMetadata = await Promise.all(
  Object.values(images).map((img) => img())
);

// Optimize each image for balanced performance and quality
const galleryImages = await Promise.all(
  imageMetadata.map(async (img: any) => {
    // Parallelize all image transformations for this specific image
    const [lqip, mobile, optimized, retina] = await Promise.all([
      getImage({
        src: img.default,
        width: 50, // Slightly larger for better initial look
        quality: 30,
        format: 'webp'
      }),
      getImage({
        src: img.default,
        width: 500,
        quality: 60,
        format: 'avif'
      }),
      getImage({
        src: img.default,
        width: 1000, 
        quality: 70,
        format: 'avif'
      }),
      getImage({
        src: img.default,
        width: 1600,
        quality: 60,
        format: 'avif'
      })
    ]);

    return {
      src: optimized.src,
      srcSet: `${mobile.src} 500w, ${optimized.src} 1000w, ${retina.src} 1600w`,
      placeholder: lqip.src,
      width: img.default.width,
      height: img.default.height,
    };
  })
);

// Mobile-optimized: Only show a subset of images on mobile to prevent crashes
const isMobile = false; // This is a server-side component, so we can't detect client-side here easily, 
// but we can pass the logic to the React component which ALREADY has isLite detection.
// However, to save build time and initial payload, we can just slice it here if we want a hard limit.
// Let's pass ALL but let the MasonryGallery handle the "View More" or Lite mode.

// Actually, the best way for performance is to NOT load all 33 in the DOM on mobile.
// We will pass all images but MasonryGallery will be updated to only render a few on mobile.
---

<Layout title="Gallery - Brent Zey">
  <div class="relative min-h-screen overflow-hidden">
    {/* Background Decorative Elements */}
    <div class="absolute inset-0 pixel-grid pointer-events-none" aria-hidden="true"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-synth-purple/5 blur-[120px] rounded-full pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-synth-cyan/5 blur-[150px] rounded-full pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 py-12 md:py-24 space-y-12">
      
      <section class="space-y-6 text-center max-w-4xl mx-auto animate-fade-in">
        <div class="inline-flex p-5 rounded-3xl bg-synth-purple/10 text-synth-purple mb-6 border border-synth-purple/20 relative group" aria-hidden="true">
          <Camera class="w-10 h-10 group-hover:scale-110 transition-transform duration-500" />
          <div class="absolute inset-0 rounded-3xl bg-synth-purple/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
        </div>
        
        <h1 class="text-6xl sm:text-7xl md:text-8xl font-black uppercase tracking-tighter leading-none">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-synth-purple via-synth-periwinkle to-synth-cyan synth-text-glow">
            Photography
          </span>
        </h1>
        
        <p class="text-xl md:text-2xl text-[var(--text-secondary)] leading-relaxed font-light max-w-2xl mx-auto subtle-letter-glow">
          A kinetic collection of select frames exploring landscapes, street scenes, and the geometry of daily life.
        </p>

        <div class="md:hidden p-4 rounded-2xl bg-synth-cyan/5 border border-synth-cyan/20 text-xs font-bold uppercase tracking-widest text-synth-cyan/80">
          Mobile Optimization Active // Performance Mode
        </div>
        
        <div class="pt-8 flex flex-col sm:flex-row items-center justify-center gap-6">
          <a href="https://photos.app.goo.gl/u2aaK1DFGrDbkwxx8" target="_blank" rel="noopener noreferrer" class="group relative inline-flex items-center gap-3 px-10 py-5 rounded-2xl bg-synth-purple text-white font-bold uppercase tracking-[0.2em] transition-all hover:bg-synth-cyan hover:synth-glow-cyan overflow-hidden shadow-xl" aria-label="View Brent Zey's full album on Google Photos">
            <span class="relative z-10 drop-shadow-md">View Full Album</span>
            <ExternalLink class="relative z-10 w-5 h-5 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform drop-shadow-md" aria-hidden="true" />
          </a>
        </div>
      </section>

      {/* Dynamic Masonry Gallery */}
      <section class="pt-12" aria-label="Photography gallery">
        {galleryImages.length > 0 ? (
          <MasonryGallery images={galleryImages} client:load />
        ) : (
          <div class="text-center py-24 rounded-3xl border-2 border-dashed border-[var(--border-color)] bg-[var(--card-bg)]">
            <p class="text-[var(--text-secondary)] font-bold uppercase tracking-widest">No photos found in gallery assets.</p>
          </div>
        )}
      </section>

      <div class="flex justify-center pt-12">
        <a href="https://photos.app.goo.gl/u2aaK1DFGrDbkwxx8" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors font-bold uppercase tracking-widest text-sm">
          More on Google Photos
          <ExternalLink class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" />
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Custom scroll behavior for this page */
  :global(html) {
    scroll-behavior: smooth;
  }
</style>
