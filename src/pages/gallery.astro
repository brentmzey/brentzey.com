---
import Layout from '../layouts/Layout.astro';
import { Camera, ExternalLink, Image as ImageIcon } from 'lucide-react';

const placeholders = [
  { id: 1, aspect: 'aspect-[4/3]', color: 'from-synth-cyan/20 to-synth-blue/20', delay: '0ms' },
  { id: 2, aspect: 'aspect-[3/4]', color: 'from-synth-pink/20 to-synth-purple/20', delay: '100ms' },
  { id: 3, aspect: 'aspect-square', color: 'from-synth-periwinkle/20 to-synth-cyan/20', delay: '200ms' },
  { id: 4, aspect: 'aspect-[16/9]', color: 'from-synth-purple/20 to-synth-blue/20', delay: '300ms' },
  { id: 5, aspect: 'aspect-[3/4]', color: 'from-synth-cyan/20 to-synth-pink/20', delay: '400ms' },
  { id: 6, aspect: 'aspect-[4/3]', color: 'from-synth-blue/20 to-synth-periwinkle/20', delay: '500ms' },
];
---

<Layout title="Gallery - Brent Zey">
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-24 space-y-16 animate-fade-in">
    
    <section class="space-y-6 text-center max-w-3xl mx-auto">
      <div class="inline-flex p-4 rounded-full bg-synth-purple/10 text-synth-purple mb-4" aria-hidden="true">
        <Camera class="w-10 h-10" />
      </div>
      <h1 class="text-5xl md:text-6xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-purple to-synth-cyan synth-text-glow">Photography</h1>
      <p class="text-xl text-[var(--text-secondary)] leading-relaxed font-light">
        A curated portfolio of select shots exploring landscapes, street photography, and daily life.
      </p>
      
      <div class="pt-8">
        <a href="https://photos.app.goo.gl/u2aaK1DFGrDbkwxx8" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-synth-purple/10 border border-synth-purple hover:bg-synth-purple/20 text-[var(--text-primary)] font-bold uppercase tracking-widest transition-all hover:synth-glow-pink" aria-label="View Brent Zey's full album on Google Photos">
          View Full Google Photos Album
          <ExternalLink class="w-5 h-5" aria-hidden="true" />
        </a>
      </div>
    </section>

    {/* Gallery Grid */}
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 pt-12" aria-label="Photography gallery">
      {/* 
        DEVELOPER INSTRUCTION:
        To add real images, replace the inner <div> containing the gradients with standard <img> tags.
        Ensure you use absolute or hosted URLs (e.g. from a CDN or a local public/ folder).
      */}
      {placeholders.map((item) => (
        <div class={`relative group rounded-3xl overflow-hidden bg-[var(--card-bg)] border border-[var(--border-color)] hover:border-synth-cyan/50 transition-all duration-500 hover:synth-glow-cyan animate-fade-in`} style={`animation-delay: ${item.delay}`}>
          
          {/* Placeholder Gradient Background */}
          <div class={`w-full ${item.aspect} bg-gradient-to-br ${item.color} flex flex-col items-center justify-center relative overflow-hidden`} role="img" aria-label={`Placeholder for image ${item.id}`}>
            
            {/* Animated Scanline Effect */}
            <div class="absolute inset-0 bg-[linear-gradient(transparent_50%,rgba(0,0,0,0.1)_50%)] bg-[length:100%_4px] opacity-20 pointer-events-none" aria-hidden="true"></div>
            
            <ImageIcon class="w-12 h-12 text-[var(--text-secondary)] opacity-50 mb-4 group-hover:scale-110 transition-transform duration-500" aria-hidden="true" />
            <span class="text-xs font-bold uppercase tracking-widest text-[var(--text-secondary)] opacity-50">Image {item.id} Placeholder</span>
          </div>

          {/* Hover Overlay */}
          <div class="absolute inset-0 bg-[var(--bg-primary)]/80 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center border-2 border-transparent group-hover:border-synth-cyan rounded-3xl" aria-hidden="true">
            <span class="font-bold text-synth-cyan uppercase tracking-widest">View Image</span>
          </div>
        </div>
      ))}
    </section>

  </div>
</Layout>
