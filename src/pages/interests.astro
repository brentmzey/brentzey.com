---
import Layout from '../layouts/Layout.astro';
import { Coffee, Plane, Code2, Headphones, Activity, Music } from 'lucide-react';

const interests = [
  {
    icon: Headphones,
    title: "Music & Curation",
    color: "text-synth-purple",
    bgColor: "bg-synth-purple/10",
    borderColor: "hover:border-synth-purple/50",
    description: "A profound passion for auditory storytelling. From the intricate structures of Classical and Jazz to the raw energy of Hip-Hop, Rap, and Alternative. I meticulously curate my library on Apple Music and keep it synced with Spotify to share the vibes.",
    links: [
      { label: "Apple Music", url: "https://music.apple.com/profile/brentzey", color: "hover:text-[#fa243c]" },
      { label: "Spotify", url: "https://open.spotify.com/user/1261049078?si=i86wEaEGQnGJOycnCn0pJg", color: "hover:text-[#1DB954]" }
    ]
  },
  {
    icon: Coffee,
    title: "Craft Coffee",
    color: "text-[#FFDD00]",
    bgColor: "bg-[#FFDD00]/10",
    borderColor: "hover:border-[#FFDD00]/50",
    description: "Exploring the nuances of specialty coffee, from bean origin to the perfect pour-over extraction. A daily ritual of precision and taste."
  },
  {
    icon: Plane,
    title: "Travel",
    color: "text-synth-cyan",
    bgColor: "bg-synth-cyan/10",
    borderColor: "hover:border-synth-cyan/50",
    description: "Experiencing new cultures, architecture, and landscapes. Travel fuels my creativity and provides fresh perspectives on life and design."
  },
  {
    icon: Activity,
    title: "Fitness & Health",
    color: "text-synth-pink",
    bgColor: "bg-synth-pink/10",
    borderColor: "hover:border-synth-pink/50",
    description: "Maintaining a balance between the digital world and physical well-being through weightlifting, running, and active living."
  }
];
---

<Layout title="Interests - Brent Zey">
  <div class="max-w-4xl mx-auto px-6 py-16 md:py-24 space-y-24 animate-fade-in">
    
    <section class="space-y-6">
      <h1 class="text-3xl sm:text-5xl md:text-6xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-periwinkle to-synth-cyan synth-text-glow">Interests & Hobbies</h1>
      <p class="text-xl md:text-2xl text-[var(--text-secondary)] leading-relaxed font-light">
        Life beyond the terminal. The pursuits and passions that keep me grounded, inspired, and constantly learning.
      </p>
    </section>

    {/* Featured Music Section */}
    <section class="space-y-8">
      <div class="p-1 rounded-[2.5rem] bg-gradient-to-r from-synth-purple via-synth-pink to-synth-cyan animate-pulse opacity-70 blur-sm absolute -z-10 w-full h-full max-w-4xl" aria-hidden="true"></div>
      <div class="relative overflow-hidden rounded-[2.5rem] bg-[var(--card-bg)] border border-[var(--border-color)] p-8 md:p-12 shadow-2xl backdrop-blur-xl">
        <div class="flex flex-col md:flex-row gap-12 items-center">
          <div class="flex-1 space-y-6 text-center md:text-left">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-synth-purple/10 text-synth-purple text-xs font-bold uppercase tracking-widest">
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-synth-purple opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-synth-purple"></span>
              </span>
              Now Spinning
            </div>
            <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter">Sonic Landscapes</h2>
            <p class="text-[var(--text-secondary)] text-lg leading-relaxed">
              Music isn't just background noise; it's the architecture of my focus. My rotations range from <strong>Classical</strong> and <strong>Jazz</strong> for deep work to <strong>Hip-Hop</strong>, <strong>Rap</strong>, and <strong>Alternative</strong> for everything else.
            </p>
            <div class="flex flex-wrap justify-center md:justify-start gap-4">
              <a href="https://music.apple.com/profile/brentzey" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-[#fa243c]/10 text-[#fa243c] hover:bg-[#fa243c] hover:text-white transition-all font-bold uppercase tracking-widest text-sm border border-[#fa243c]/20" aria-label="Visit Brent Zey's Apple Music Profile">
                <Music class="w-5 h-5" aria-hidden="true" />
                Apple Music
              </a>
              <a href="https://open.spotify.com/user/1261049078?si=i86wEaEGQnGJOycnCn0pJg" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-[#1DB954]/10 text-[#1DB954] hover:bg-[#1DB954] hover:text-white transition-all font-bold uppercase tracking-widest text-sm border border-[#1DB954]/20" aria-label="Visit Brent Zey's Spotify Profile">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-.1.24-2.82-1.74-6.36-2.1-10.561-1.141-.418.122-.779-.179-.839-.539-.121-.418.179-.779.539-.839 4.5-.961 8.461-.539 11.641 1.5.359.24.48.66.24 1.021zM18.961 14.1c-.3.479-.9.6-1.379.3-3.239-1.979-8.159-2.519-11.939-1.38-.54.18-.1.019-.3.42-.18.54-.779.84-1.319.66-.54-.18-.84-.779-.66-1.319 4.38-1.32 9.78-.719 13.5 1.559.48.3.6.9.3 1.38zM19.08 10.68c-3.9-2.341-10.32-2.521-14.1-1.441a1.2 1.2 0 11-.661-2.34c4.321-1.321 11.401-1.021 15.9 1.681a1.2 1.2 0 01-1.14 2.1z"/></svg>
                Spotify
              </a>
            </div>
          </div>
          <div class="w-full md:w-[320px] aspect-square relative group" aria-hidden="true">
            <div class="absolute inset-0 bg-gradient-to-br from-synth-purple to-synth-pink rounded-[2rem] rotate-6 opacity-20 group-hover:rotate-12 transition-transform"></div>
            <div class="relative w-full h-full rounded-[2rem] bg-black/40 overflow-hidden border border-white/10 flex flex-col items-center justify-center p-6 space-y-6">
              {/* Fake Player UI */}
              <div class="w-48 h-48 rounded-2xl bg-gradient-to-tr from-gray-800 to-gray-700 shadow-2xl flex items-center justify-center relative overflow-hidden group/disk">
                <div class="absolute inset-4 rounded-full border-4 border-white/5 animate-[spin_8s_linear_infinite] group-hover/disk:animate-none">
                  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 rounded-full bg-black/20"></div>
                </div>
                <Music class="w-16 h-16 text-synth-purple/40" />
              </div>
              <div class="w-full space-y-2 text-center">
                <div class="h-2 w-full bg-white/10 rounded-full overflow-hidden">
                  <div class="h-full w-1/3 bg-gradient-to-r from-synth-purple to-synth-pink animate-pulse"></div>
                </div>
                <div class="flex justify-between text-[10px] text-white/40 font-mono uppercase tracking-tighter">
                  <span>01:24</span>
                  <span>04:12</span>
                </div>
              </div>
              <div class="flex items-center gap-6 text-white/60">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6 18V6h2v12H6zm3.5-6L18 6v12l-8.5-6z"/></svg>
                <div class="p-3 rounded-full bg-white text-black hover:scale-110 transition-transform cursor-pointer">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M16 18V6h-2v12h2zM6 12l8.5 6V6L6 12z"/></svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {interests.map((item) => {
        const Icon = item.icon;
        return (
          <div class={`group p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] transition-all ${item.borderColor} hover:shadow-lg flex flex-col h-full`}>
            <div class="flex items-center gap-4 mb-6">
              <div class={`p-4 rounded-2xl ${item.bgColor} ${item.color} group-hover:scale-110 transition-transform`} aria-hidden="true">
                <Icon class="w-8 h-8" />
              </div>
              <h2 class="text-2xl font-bold uppercase tracking-wider">{item.title}</h2>
            </div>
            <p class="text-[var(--text-secondary)] leading-relaxed text-lg flex-grow">
              {item.description}
            </p>
            {item.links && (
              <div class="flex gap-6 mt-6 pt-6 border-t border-[var(--border-color)]">
                {item.links.map(link => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class={`flex items-center gap-2 text-sm font-bold uppercase tracking-widest ${link.color} transition-colors group/link`} aria-label={`Brent Zey's ${link.label} Profile`}>
                    {link.label === "Apple Music" ? (
                      <Music class="w-4 h-4 transition-transform group-hover/link:scale-110" aria-hidden="true" />
                    ) : (
                      <svg class="w-4 h-4 transition-transform group-hover/link:scale-110" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-.1.24-2.82-1.74-6.36-2.1-10.561-1.141-.418.122-.779-.179-.839-.539-.121-.418.179-.779.539-.839 4.5-.961 8.461-.539 11.641 1.5.359.24.48.66.24 1.021zM18.961 14.1c-.3.479-.9.6-1.379.3-3.239-1.979-8.159-2.519-11.939-1.38-.54.18-.1.019-.3.42-.18.54-.779.84-1.319.66-.54-.18-.84-.779-.66-1.319 4.38-1.32 9.78-.719 13.5 1.559.48.3.6.9.3 1.38zM19.08 10.68c-3.9-2.341-10.32-2.521-14.1-1.441a1.2 1.2 0 11-.661-2.34c4.321-1.321 11.401-1.021 15.9 1.681a1.2 1.2 0 01-1.14 2.1z"/></svg>
                    )}
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </section>

  </div>
</Layout>
