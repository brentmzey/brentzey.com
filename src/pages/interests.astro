---
import Layout from '../layouts/Layout.astro';
import { Coffee, Plane, Code2, Headphones, Activity, Music } from 'lucide-react';
import MusicStatus from '../components/MusicStatus.tsx';

const interests = [
  {
    icon: Headphones,
    title: "Music & Curation",
    color: "text-synth-purple",
    bgColor: "bg-synth-purple/10",
    borderColor: "hover:border-synth-purple/50",
    description: "A profound passion for auditory storytelling. From the intricate structures of Classical and Jazz to the raw energy of Hip-Hop, Rap, and Alternative. I meticulously curate my library on Apple Music and keep it synced with Spotify to share the vibes.",
    links: [
      { label: "Apple Music", url: "https://music.apple.com/profile/brentzey", color: "hover:text-[#FC3C44]" },
      { label: "Spotify", url: "https://open.spotify.com/user/1261049078?si=i86wEaEGQnGJOycnCn0pJg", color: "hover:text-[#1ED760]" }
    ]
  },
  {
    icon: Coffee,
    title: "Craft Coffee",
    color: "text-[#FFDD00]",
    bgColor: "bg-[#FFDD00]/10",
    borderColor: "hover:border-[#FFDD00]/50",
    description: "Exploring the nuances of specialty coffee, from bean origin to the perfect pour-over extraction. A daily ritual of precision and taste."
  },
  {
    icon: Plane,
    title: "Travel",
    color: "text-synth-cyan",
    bgColor: "bg-synth-cyan/10",
    borderColor: "hover:border-synth-cyan/50",
    description: "Experiencing new cultures, architecture, and landscapes. Travel fuels my creativity and provides fresh perspectives on life and design."
  },
  {
    icon: Activity,
    title: "Fitness & Health",
    color: "text-synth-pink",
    bgColor: "bg-synth-pink/10",
    borderColor: "hover:border-synth-pink/50",
    description: "Maintaining a balance between the digital world and physical well-being through weightlifting, running, and active living."
  }
];
---

<Layout title="Interests - Brent Zey">
  <div class="max-w-4xl mx-auto px-6 py-12 md:py-24 space-y-16 md:space-y-24 animate-fade-in">
    
    <section class="space-y-6">
      <h1 class="text-5xl sm:text-5xl md:text-6xl font-black uppercase tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-periwinkle to-synth-cyan synth-text-glow">Interests & Hobbies</h1>
      <p class="text-xl md:text-2xl text-[var(--text-secondary)] leading-relaxed font-light">
        Life beyond the terminal. The pursuits and passions that keep me grounded, inspired, and constantly learning.
      </p>
    </section>

    {/* Featured Music Section */}
    <section class="relative group">
      {/* Dynamic Background Glow - More flexible and responsive */}
      <div class="absolute -inset-4 bg-gradient-to-r from-synth-purple/20 via-synth-pink/20 to-synth-cyan/20 blur-3xl rounded-[3rem] opacity-50 group-hover:opacity-80 transition-opacity duration-700 -z-10" aria-hidden="true"></div>
      <div class="absolute inset-0 p-1 rounded-[2.5rem] bg-gradient-to-r from-synth-purple via-synth-pink to-synth-cyan opacity-20 blur-sm -z-10" aria-hidden="true"></div>
      
      <div class="relative overflow-hidden rounded-[2.5rem] bg-[var(--card-bg)] border border-[var(--border-color)] p-6 md:p-12 shadow-2xl backdrop-blur-xl">
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-center">
          <div class="flex-1 space-y-6 text-center md:text-left">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-synth-purple/10 text-synth-purple text-xs font-bold uppercase tracking-widest">
              <span class="relative flex h-2 w-2" aria-hidden="true">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-synth-purple opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-synth-purple"></span>
              </span>
              Now Spinning
            </div>
            <h2 class="text-4xl md:text-5xl font-black uppercase tracking-tighter leading-none">Sonic Landscapes</h2>
            <p class="text-[var(--text-secondary)] text-lg leading-relaxed">
              Music isn't just background noise; it's the architecture of my focus. My rotations range from <strong>Classical</strong> and <strong>Jazz</strong> for deep work to <strong>Hip-Hop</strong>, <strong>Rap</strong>, and <strong>Alternative</strong> for everything else.
            </p>
            
            {/* Live Status Component - Fetches from /api/now-playing */}
            <MusicStatus client:load />

            <div class="flex flex-wrap justify-center md:justify-start gap-6">
              <a href="https://music.apple.com/profile/brentzey" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-3.5 rounded-2xl bg-[#FC3C44]/10 text-[#FC3C44] hover:bg-[#FC3C44] hover:text-white transition-all font-bold uppercase tracking-widest text-sm border border-[#FC3C44]/20 shadow-lg hover:shadow-[#FC3C44]/40 hover:-translate-y-1 active:scale-95 group" aria-label="Visit Brent Zey's Apple Music Profile">
                <svg class="w-5 h-5 fill-current" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Apple Music</title><path d="M23.994 6.124a9.23 9.23 0 00-.24-2.19c-.317-1.31-1.062-2.31-2.18-3.043a5.022 5.022 0 00-1.877-.726 10.496 10.496 0 00-1.564-.15c-.04-.003-.083-.01-.124-.013H5.986c-.152.01-.303.017-.455.026-.747.043-1.49.123-2.193.4-1.336.53-2.3 1.452-2.865 2.78-.192.448-.292.925-.363 1.408-.056.392-.088.785-.1 1.18 0 .032-.007.062-.01.093v12.223c.01.14.017.283.027.424.05.815.154 1.624.497 2.373.65 1.42 1.738 2.353 3.234 2.801.42.127.856.187 1.293.228.555.053 1.11.06 1.667.06h11.03a12.5 12.5 0 001.57-.1c.822-.106 1.596-.35 2.295-.81a5.046 5.046 0 001.88-2.207c.186-.42.293-.87.37-1.324.113-.675.138-1.358.137-2.04-.002-3.8 0-7.595-.003-11.393zm-6.423 3.99v5.712c0 .417-.058.827-.244 1.206-.29.59-.76.962-1.388 1.14-.35.1-.706.157-1.07.173-.95.045-1.773-.6-1.943-1.536a1.88 1.88 0 011.038-2.022c.323-.16.67-.25 1.018-.324.378-.082.758-.153 1.134-.24.274-.063.457-.23.51-.516a.904.904 0 00.02-.193c0-1.815 0-3.63-.002-5.443a.725.725 0 00-.026-.185c-.04-.15-.15-.243-.304-.234-.16.01-.318.035-.475.066-.76.15-1.52.303-2.28.456l-2.325.47-1.374.278c-.016.003-.032.01-.048.013-.277.077-.377.203-.39.49-.002.042 0 .086 0 .13-.002 2.602 0 5.204-.003 7.805 0 .42-.047.836-.215 1.227-.278.64-.77 1.04-1.434 1.233-.35.1-.71.16-1.075.172-.96.036-1.755-.6-1.92-1.544-.14-.812.23-1.685 1.154-2.075.357-.15.73-.232 1.108-.31.287-.06.575-.116.86-.177.383-.083.583-.323.6-.714v-.15c0-2.96 0-5.922.002-8.882 0-.123.013-.25.042-.37.07-.285.273-.448.546-.518.255-.066.515-.112.774-.165.733-.15 1.466-.296 2.2-.444l2.27-.46c.67-.134 1.34-.27 2.01-.403.22-.043.442-.088.663-.106.31-.025.523.17.554.482.008.073.012.148.012.223.002 1.91.002 3.822 0 5.732z"/></svg>
                Apple Music
              </a>
              <a href="https://open.spotify.com/user/1261049078?si=i86wEaEGQnGJOycnCn0pJg" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 px-6 py-3.5 rounded-2xl bg-[#1ED760]/10 text-[#1ED760] hover:bg-[#1ED760] hover:text-white transition-all font-bold uppercase tracking-widest text-sm border border-[#1ED760]/20 shadow-lg hover:shadow-[#1ED760]/40 hover:-translate-y-1 active:scale-95 group" aria-label="Visit Brent Zey's Spotify Profile">
                <svg class="w-5 h-5 fill-current" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Spotify</title><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                Spotify
              </a>
            </div>
          </div>
          <div class="w-full md:w-[400px] rounded-[2.5rem] overflow-hidden shadow-2xl border border-white/10 group/player transform transition-all hover:scale-[1.02] bg-black/20" aria-hidden="true">
            {/* Real Apple Music Embed - This shows a functional player */}
            <iframe 
              allow="autoplay *; encrypted-media *; fullscreen *; clipboard-write" 
              frameborder="0" 
              height="450" 
              style="width:100%;max-width:100%;overflow:hidden;background:transparent;" 
              sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation" 
              src="https://embed.music.apple.com/us/playlist/heavy-rotation/pl.u-38oWWXvFY56E1k">
            </iframe>
          </div>
        </div>
      </div>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 relative">
      {interests.map((item) => {
        const Icon = item.icon;
        return (
          <div class="relative group h-full">
            {/* Individual Card Glow */}
            <div class={`absolute -inset-2 ${item.bgColor} blur-2xl rounded-3xl opacity-20 group-hover:opacity-60 transition-all duration-500 -z-10`} aria-hidden="true"></div>
            
            <div class={`group p-6 md:p-8 rounded-3xl bg-[var(--card-bg)] border border-[var(--border-color)] transition-all ${item.borderColor} hover:shadow-lg flex flex-col h-full relative z-10 backdrop-blur-sm`}>
              <div class="flex items-center gap-4 mb-6">
                <div class={`p-4 rounded-2xl ${item.bgColor} ${item.color} group-hover:scale-110 transition-transform`} aria-hidden="true">
                  <Icon class="w-8 h-8" />
                </div>
                <h2 class="text-xl md:text-2xl font-bold uppercase tracking-wider">{item.title}</h2>
              </div>
              <p class="text-[var(--text-secondary)] leading-relaxed text-base md:text-lg flex-grow">
                {item.description}
              </p>
              {item.links && (
                <div class="flex gap-6 mt-6 pt-6 border-t border-[var(--border-color)]">
                  {item.links.map(link => (
                    <a href={link.url} target="_blank" rel="noopener noreferrer" class={`flex items-center gap-2 text-sm font-bold uppercase tracking-widest ${link.color} transition-colors group/link`} aria-label={`Brent Zey's ${link.label} Profile`}>
                      {link.label === "Apple Music" ? (
                        <Music class="w-4 h-4 transition-transform group-hover/link:scale-110" aria-hidden="true" />
                      ) : (
                        <svg class="w-4 h-4 transition-transform group-hover/link:scale-110" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-.1.24-2.82-1.74-6.36-2.1-10.561-1.141-.418.122-.779-.179-.839-.539-.121-.418.179-.779.539-.839 4.5-.961 8.461-.539 11.641 1.5.359.24.48.66.24 1.021zM18.961 14.1c-.3.479-.9.6-1.379.3-3.239-1.979-8.159-2.519-11.939-1.38-.54.18-.1.019-.3.42-.18.54-.779.84-1.319.66-.54-.18-.84-.779-.66-1.319 4.38-1.32 9.78-.719 13.5 1.559.48.3.6.9.3 1.38zM19.08 10.68c-3.9-2.341-10.32-2.521-14.1-1.441a1.2 1.2 0 11-.661-2.34c4.321-1.321 11.401-1.021 15.9 1.681a1.2 1.2 0 01-1.14 2.1z"/></svg>
                      )}
                      {link.label}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </section>

  </div>
</Layout>
