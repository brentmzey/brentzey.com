---
import '../styles/global.css';
import { Coffee, Moon, Sun, MonitorSmartphone, Code2, Camera, User } from 'lucide-react';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Brent Zey - Software Engineer" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#020617" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32">
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" href="/favicon.png">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Theme initialization
      const getTheme = () => {
        const saved = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        if (saved && saved !== 'system') return saved;
        return 'system';
      };

      const applyTheme = (theme) => {
        const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', isDark);
        
        // Update toggle UI if elements exist
        const thumb = document.getElementById('themeThumb');
        const thumbMobile = document.getElementById('themeThumbMobile');
        
        const positions = { light: '4px', system: '36px', dark: '68px' };
        const positionsMobile = { light: '4px', system: '32px', dark: '60px' };
        
        if (thumb) {
          thumb.style.left = positions[theme];
          // Show correct icon in thumb
          ['Sun', 'System', 'Moon'].forEach(mode => {
            const icon = document.getElementById(`thumbIcon${mode}`);
            if (icon) icon.classList.toggle('hidden', mode.toLowerCase() !== theme);
          });
        }
        if (thumbMobile) {
          thumbMobile.style.left = positionsMobile[theme];
          ['Sun', 'System', 'Moon'].forEach(mode => {
            const icon = document.getElementById(`thumbIcon${mode}Mobile`);
            if (icon) icon.classList.toggle('hidden', mode.toLowerCase() !== theme);
          });
        }
      };

      const theme = getTheme();
      applyTheme(theme);

      // Listen for system changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (getTheme() === 'system') applyTheme('system');
      });
    </script>
  </head>
  <body class="bg-[var(--bg-primary)] text-[var(--text-primary)] font-sans antialiased min-h-screen flex flex-col selection:bg-synth-pink selection:text-white transition-colors duration-300 overflow-hidden">
    
    {/* Parallax Wrapper */}
    <div class="parallax-container h-screen w-full">
      
      {/* Background Layers */}
      <div class="parallax-layer parallax-bg-slow pointer-events-none">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,var(--accent-glow),transparent)] opacity-40"></div>
        <div class="absolute inset-0 pixel-grid"></div>
        <div class="absolute inset-0 techno-lines opacity-20"></div>
        
        {/* Digital Rain / Dripping Lines */}
        <div class="digital-rain">
          {Array.from({ length: 45 }).map((_, i) => {
            const colors = ['#00f3ff', '#9d00ff', '#ff00ea', '#a49aff'];
            const color = colors[i % colors.length];
            // Structured distribution: divide screen into 45 segments with random jitter
            const left = (i * (100 / 45)) + (Math.random() * 2 - 1);
            const delay = (Math.random() * 8).toFixed(2);
            const duration = (4 + Math.random() * 6).toFixed(2);
            return (
              <div 
                class="rain-column" 
                style={`left: ${left}%; animation-delay: ${delay}s; animation-duration: ${duration}s; --rain-color: ${color};`}
              ></div>
            );
          })}
        </div>
      </div>

      <div class="parallax-layer parallax-bg-med pointer-events-none">
        <div class="absolute top-[20%] left-[10%] w-64 h-64 bg-synth-cyan/10 blur-[120px] rounded-full animate-float"></div>
        <div class="absolute bottom-[20%] right-[10%] w-96 h-96 bg-synth-pink/10 blur-[150px] rounded-full animate-float" style="animation-delay: -2s"></div>
      </div>

      {/* Main Content Layer */}
      <div class="parallax-layer z-10 flex flex-col min-h-full">
        {/* Navigation */}
        <nav class="sticky top-0 z-50 backdrop-blur-md bg-[var(--nav-bg)] border-b border-[var(--border-color)] transition-colors duration-300">
          <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
              <a href="/" class="flex items-center gap-2 group">
                <span class="text-xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-cyan to-synth-pink uppercase group-hover:synth-text-glow transition-all">
                  BRENT.ZEY
                </span>
              </a>
              
              <div class="hidden md:flex items-center space-x-8">
                <a href="/about" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors text-sm font-semibold uppercase tracking-widest"><User class="w-4 h-4"/> About</a>
                <a href="/work" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-pink transition-colors text-sm font-semibold uppercase tracking-widest"><Code2 class="w-4 h-4"/> Work</a>
                <a href="/gallery" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors text-sm font-semibold uppercase tracking-widest"><Camera class="w-4 h-4"/> Gallery</a>
                <a href="/interests" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-purple transition-colors text-sm font-semibold uppercase tracking-widest"><MonitorSmartphone class="w-4 h-4"/> Interests</a>
                
                <div class="relative flex items-center p-1 rounded-full bg-[var(--card-bg)] border border-[var(--border-color)] w-[100px] h-10 shadow-inner group/toggle">
                  <div id="themeThumb" class="absolute top-[4px] left-[4px] w-7 h-7 rounded-full bg-white dark:bg-slate-800 shadow-lg transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] flex items-center justify-center pointer-events-none z-20">
                    <Sun id="thumbIconSun" class="w-4 h-4 text-yellow-500 hidden" />
                    <MonitorSmartphone id="thumbIconSystem" class="w-4 h-4 text-synth-cyan hidden" />
                    <Moon id="thumbIconMoon" class="w-4 h-4 text-synth-purple hidden" />
                  </div>

                  <button id="modeLight" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-synth-cyan rounded-l-full" aria-label="Switch to Light Mode" title="Light Mode">
                    <Sun class="w-4 h-4 text-yellow-500" />
                  </button>
                  <button id="modeSystem" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-synth-cyan" aria-label="Switch to System Mode" title="System Mode">
                    <MonitorSmartphone class="w-4 h-4 text-synth-cyan" />
                  </button>
                  <button id="modeDark" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-synth-cyan rounded-r-full" aria-label="Switch to Dark Mode" title="Dark Mode">
                    <Moon class="w-4 h-4 text-synth-purple" />
                  </button>
                </div>
                
                <a href="https://buymeacoffee.com/brentmzey4795" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-full bg-[#FFDD00] hover:bg-[#FFDD00]/90 text-black font-bold text-sm transition-transform hover:scale-105 shadow-lg shadow-[#FFDD00]/20">
                  <Coffee class="w-4 h-4" />
                  Support Me
                </a>
              </div>

              {/* Mobile menu button */}
              <div class="md:hidden flex items-center gap-4">
                <div class="relative flex items-center p-1 rounded-full bg-[var(--card-bg)] border border-[var(--border-color)] w-[90px] h-9 shadow-inner">
                  <div id="themeThumbMobile" class="absolute top-[4px] left-[4px] w-6 h-6 rounded-full bg-white dark:bg-slate-800 shadow-md transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] flex items-center justify-center pointer-events-none z-20">
                    <Sun id="thumbIconSunMobile" class="w-3.5 h-3.5 text-yellow-500 hidden" />
                    <MonitorSmartphone id="thumbIconSystemMobile" class="w-3.5 h-3.5 text-synth-cyan hidden" />
                    <Moon id="thumbIconMoonMobile" class="w-3.5 h-3.5 text-synth-purple hidden" />
                  </div>
                  <button id="modeLightMobile" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40" aria-label="Light Mode"><Sun class="w-3.5 h-3.5 text-yellow-500" /></button>
                  <button id="modeSystemMobile" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40" aria-label="System Mode"><MonitorSmartphone class="w-3.5 h-3.5 text-synth-cyan" /></button>
                  <button id="modeDarkMobile" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40" aria-label="Dark Mode"><Moon class="w-3.5 h-3.5 text-synth-purple" /></button>
                </div>
              </div>
            </div>
          </div>
        </nav>

        <main class="flex-grow">
          <slot />
        </main>

        <footer class="border-t border-[var(--border-color)] py-12 mt-20 text-center space-y-4 bg-[var(--nav-bg)] backdrop-blur-md">
          <div class="flex justify-center gap-6">
            <a href="https://github.com/brentmzey" class="text-[var(--text-secondary)] hover:text-synth-cyan transition-colors">GitHub</a>
            <a href="mailto:brentmzey4795@gmail.com" class="text-[var(--text-secondary)] hover:text-synth-pink transition-colors">Email</a>
          </div>
          <p class="text-[var(--text-secondary)] text-sm">&copy; {new Date().getFullYear()} Brent Zey. All rights reserved.</p>
        </footer>
      </div>
    </div>

    <script is:inline>
      const setupToggle = (id, theme) => {
        document.getElementById(id)?.addEventListener('click', () => {
          localStorage.setItem('theme', theme);
          applyTheme(theme);
        });
      };

      // Desktop
      setupToggle('modeLight', 'light');
      setupToggle('modeSystem', 'system');
      setupToggle('modeDark', 'dark');

      // Mobile
      setupToggle('modeLightMobile', 'light');
      setupToggle('modeSystemMobile', 'system');
      setupToggle('modeDarkMobile', 'dark');

      // Initial UI Sync
      window.addEventListener('DOMContentLoaded', () => {
        applyTheme(getTheme());
      });
    </script>
  </body>
</html>
  </body>
</html>
