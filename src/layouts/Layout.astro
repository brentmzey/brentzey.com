---
import '../styles/global.css';
import { Coffee, Moon, Sun, MonitorSmartphone, Code2, Camera, User, Github, Mail, Music } from 'lucide-react';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Brent Zey - Software Engineer" } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#020617" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32">
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="icon" href="/favicon.png">
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      // Theme initialization
      const getTheme = () => {
        const saved = typeof localStorage !== 'undefined' ? localStorage.getItem('theme') : null;
        if (saved && saved !== 'system') return saved;
        return 'system';
      };

      const applyTheme = (theme) => {
        const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.classList.toggle('dark', isDark);
        
        // Update toggle UI if elements exist
        const thumb = document.getElementById('themeThumb');
        const thumbMobile = document.getElementById('themeThumbMobile');
        
        const positions = { light: '4px', system: '36px', dark: '68px' };
        const positionsMobile = { light: '4px', system: '32px', dark: '60px' };
        
        if (thumb) {
          thumb.style.left = positions[theme];
          // Show correct icon in thumb
          ['Sun', 'System', 'Moon'].forEach(mode => {
            const icon = document.getElementById(`thumbIcon${mode}`);
            if (icon) icon.classList.toggle('hidden', mode.toLowerCase() !== theme);
          });
        }
        if (thumbMobile) {
          thumbMobile.style.left = positionsMobile[theme];
          ['Sun', 'System', 'Moon'].forEach(mode => {
            const icon = document.getElementById(`thumbIcon${mode}Mobile`);
            if (icon) icon.classList.toggle('hidden', mode.toLowerCase() !== theme);
          });
        }
      };

      const theme = getTheme();
      applyTheme(theme);

      // Listen for system changes
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
        if (getTheme() === 'system') applyTheme('system');
      });
    </script>
  </head>
  <body class="bg-[var(--bg-primary)] text-[var(--text-primary)] font-sans antialiased min-h-screen flex flex-col selection:bg-synth-pink selection:text-white transition-colors duration-300">
    
    {/* Fixed Background Layers - Seamless & Always On Screen */}
    <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,var(--accent-glow),transparent)] opacity-60"></div>
      <div class="absolute inset-0 pixel-grid"></div>
      <div class="absolute inset-0 techno-lines opacity-30"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-synth-cyan/10 via-transparent to-synth-pink/10 opacity-40"></div>
      
      {/* Flowing Water Background Glow - Disabled on mobile for performance */}
      <div class="water-flow-container hidden md:block">
        <div class="water-blob top-[10%] left-[10%]"></div>
        <div class="water-blob bottom-[20%] right-[10%]"></div>
        <div class="water-blob top-[40%] right-[30%]"></div>
        <div class="water-blob bottom-[10%] left-[20%]"></div>
      </div>

      {/* Digital Rain / Dripping Dots - Optimized for performance */}
      <div class="digital-rain">
        {Array.from({ length: 12 }).map((_, i) => {
          const colors = ['#00f3ff', '#9d00ff', '#ff00ea', '#a49aff'];
          const color = colors[i % colors.length];
          
          const left = (Math.random() * 100).toFixed(2);
          const delay = (Math.random() * 15).toFixed(2);
          const duration = (5 + Math.random() * 10).toFixed(2);
          const startPos = -(200 + Math.random() * 300);
          
          const depth = Math.random();
          const size = (1 + depth * 2).toFixed(1);
          const opacity = (0.2 + depth * 0.4).toFixed(2);
          const speedMultiplier = 0.6 + depth * 1.2;
          const finalDuration = (duration / speedMultiplier).toFixed(2);

          return (
            <div 
              class={`dotted-column ${i > 4 ? 'hidden md:block' : ''}`}
              style={`
                left: ${left}%; 
                top: ${startPos}px; 
                animation-delay: ${delay}s; 
                animation-duration: ${finalDuration}s; 
                --rain-color: ${color};
                --rain-size: ${size}px;
                --rain-opacity: ${opacity};
              `}
            ></div>
          );
        })}
      </div>

      <div class="absolute top-[20%] left-[10%] w-64 h-64 bg-synth-cyan/10 blur-[100px] rounded-full animate-float md:block hidden"></div>
      <div class="absolute bottom-[20%] right-[10%] w-96 h-96 bg-synth-pink/10 blur-[120px] rounded-full animate-float md:block hidden" style="animation-delay: -2s"></div>
    </div>

    {/* Navigation - Fixed to Viewport */}
    <nav class="hidden md:block fixed top-0 left-0 right-0 z-50 liquid-glass border-x-0 border-t-0 border-b transition-all duration-300">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2 group relative">
            <span class="text-xl font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-cyan via-synth-purple to-synth-pink uppercase group-hover:synth-text-glow-strong transition-all synth-text-glow relative z-10">
              BRENT ZEY
            </span>
            <div class="neon-glow-container opacity-0 group-hover:opacity-100 transition-opacity hidden md:flex">
              <div class="neon-glow-rotating"></div>
              <div class="neon-glow-rotating-alt"></div>
            </div>
            <div class="absolute -inset-2 bg-synth-cyan/5 blur-xl -z-10 rounded-full group-hover:bg-synth-cyan/10 transition-colors"></div>
          </a>
          
          <div class="flex items-center space-x-6">
            <a href="/about" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors text-sm font-semibold uppercase tracking-widest"><User class="w-4 h-4" aria-hidden="true"/> About</a>
            <a href="/work" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-pink transition-colors text-sm font-semibold uppercase tracking-widest"><Code2 class="w-4 h-4" aria-hidden="true"/> Work</a>
            <a href="/gallery" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors text-sm font-semibold uppercase tracking-widest"><Camera class="w-4 h-4" aria-hidden="true"/> Gallery</a>
            <a href="/interests" class="flex items-center gap-1 text-[var(--text-secondary)] hover:text-synth-purple transition-colors text-sm font-semibold uppercase tracking-widest"><MonitorSmartphone class="w-4 h-4" aria-hidden="true"/> Interests</a>
            
            <div class="relative flex items-center p-1 rounded-full liquid-glass w-[100px] h-10 shadow-inner group/toggle" role="group" aria-label="Theme selection">
              <div id="themeThumb" class="absolute top-[4px] left-[4px] w-7 h-7 rounded-full bg-white/20 backdrop-blur-md shadow-lg transition-all duration-300 ease-[cubic-bezier(0.34,1.56,0.64,1)] flex items-center justify-center pointer-events-none z-20 border border-white/30">
                <Sun id="thumbIconSun" class="w-4 h-4 text-yellow-500 hidden" aria-hidden="true" />
                <MonitorSmartphone id="thumbIconSystem" class="w-4 h-4 text-synth-cyan hidden" aria-hidden="true" />
                <Moon id="thumbIconMoon" class="w-4 h-4 text-synth-purple hidden" aria-hidden="true" />
              </div>

              <button id="modeLight" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-synth-cyan rounded-l-full" aria-label="Switch to Light Mode" title="Light Mode">
                <Sun class="w-4 h-4 text-yellow-500" aria-hidden="true" />
              </button>
              <button id="modeSystem" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-synth-cyan" aria-label="Switch to System Mode" title="System Mode">
                <MonitorSmartphone class="w-4 h-4 text-synth-cyan" aria-hidden="true" />
              </button>
              <button id="modeDark" class="relative z-10 flex-1 h-full flex items-center justify-center opacity-40 hover:opacity-100 transition-opacity focus:outline-none focus-visible:ring-2 focus-visible:ring-synth-cyan rounded-r-full" aria-label="Switch to Dark Mode" title="Dark Mode">
                <Moon class="w-4 h-4 text-synth-purple" aria-hidden="true" />
              </button>
            </div>
          </div>
        </div>
      </div>
    </nav>

    {/* Mobile Header - Fixed Top */}
    <header class="md:hidden fixed top-0 left-0 right-0 z-50 liquid-glass border-x-0 border-t-0 border-b px-6 pt-[env(safe-area-inset-top)] h-[calc(4rem+env(safe-area-inset-top))] flex items-center justify-between transition-all">
      <a href="/" class="relative flex items-center group">
        <span class="text-lg font-black tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-synth-cyan via-synth-purple to-synth-pink uppercase synth-text-glow relative z-10">BRENT ZEY</span>
        <div class="absolute -inset-4 bg-synth-cyan/10 blur-xl -z-10 rounded-full"></div>
      </a>
      <div class="relative flex items-center p-1 rounded-full liquid-glass w-[80px] h-8 shadow-inner" role="group" aria-label="Theme selection">
        <div id="themeThumbMobile" class="absolute top-[3px] left-[3px] w-6 h-6 rounded-full bg-white/20 backdrop-blur-md shadow-md transition-all duration-300 flex items-center justify-center pointer-events-none z-20 border border-white/20">
          <Sun id="thumbIconSunMobile" class="w-3.5 h-3.5 text-yellow-500 hidden" aria-hidden="true" />
          <MonitorSmartphone id="thumbIconSystemMobile" class="w-3.5 h-3.5 text-synth-cyan hidden" aria-hidden="true" />
          <Moon id="thumbIconMoonMobile" class="w-3.5 h-3.5 text-synth-purple hidden" aria-hidden="true" />
        </div>
        <button id="modeLightMobile" class="flex-1 h-full opacity-30" aria-label="Switch to Light Mode"><Sun class="w-3 h-3 mx-auto" aria-hidden="true"/></button>
        <button id="modeSystemMobile" class="flex-1 h-full opacity-30" aria-label="Switch to System Mode"><MonitorSmartphone class="w-3 h-3 mx-auto" aria-hidden="true"/></button>
        <button id="modeDarkMobile" class="flex-1 h-full opacity-30" aria-label="Switch to Dark Mode"><Moon class="w-3 h-3 mx-auto" aria-hidden="true"/></button>
      </div>
    </header>

    {/* Fixed Mobile Bottom Navigation Bar - Truly Always On Screen */}
    <div id="mobile-nav" class="fixed bottom-0 left-0 right-0 z-50 px-4 pb-4 md:hidden transition-all duration-500 ease-in-out opacity-100 transform translate-y-[-12px]">
      <nav class="max-w-4xl mx-auto flex items-center justify-around p-3 rounded-3xl liquid-glass shadow-2xl" aria-label="Mobile navigation">
        <a href="/" class="flex flex-col items-center gap-1 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors" aria-label="Home">
          <span class="text-[10px] font-black uppercase tracking-tighter" aria-hidden="true">Home</span>
        </a>
        <a href="/about" class="flex flex-col items-center gap-1 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors" aria-label="About">
          <User class="w-5 h-5" aria-hidden="true"/>
          <span class="text-[10px] font-bold uppercase">About</span>
        </a>
        <a href="/work" class="flex flex-col items-center gap-1 text-[var(--text-secondary)] hover:text-synth-pink transition-colors" aria-label="Work">
          <Code2 class="w-5 h-5" aria-hidden="true"/>
          <span class="text-[10px] font-bold uppercase">Work</span>
        </a>
        <a href="/gallery" class="flex flex-col items-center gap-1 text-[var(--text-secondary)] hover:text-synth-cyan transition-colors" aria-label="Gallery">
          <Camera class="w-5 h-5" aria-hidden="true"/>
          <span class="text-[10px] font-bold uppercase">Gallery</span>
        </a>
        <a href="/interests" class="flex flex-col items-center gap-1 text-[var(--text-secondary)] hover:text-synth-purple transition-colors" aria-label="Interests">
          <MonitorSmartphone class="w-5 h-5" aria-hidden="true"/>
          <span class="text-[10px] font-bold uppercase">Interests</span>
        </a>
      </nav>
    </div>

    {/* Main Scrollable Content */}
    <div class="parallax-container relative z-10 flex-grow flex flex-col">
      
      {/* Main Content Layer - Ensuring it fills the container robustly */}
      <div class="flex flex-col min-h-screen pt-20 md:pt-24 flex-grow">
        <main class="flex-grow pb-32 md:pb-0" role="main">
          <slot />
        </main>

        <div class="w-full px-4 py-12 relative z-30">
          <div class="max-w-4xl mx-auto flex flex-col items-center gap-8">
            <div class="flex flex-wrap justify-center gap-4">
              <div class="relative group/bmc reveal-on-scroll" style="transition-delay: 100ms">
                <a href="https://buymeacoffee.com/brentmzey" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-black/80 backdrop-blur-md border border-[#FFDD00]/30 text-white hover:border-[#FFDD00] transition-all shadow-[0_0_15px_rgba(255,221,0,0.1)] hover:shadow-[0_0_25px_rgba(255,221,0,0.3)] hover:scale-105" aria-label="Support Brent Zey on Buy Me A Coffee">
                  <svg class="w-5 h-5 fill-[#FFDD00]" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Buy Me A Coffee</title><path d="M20.216 6.415l-.132-.666c-.209-1.04-1.233-1.732-2.253-1.497l-9.112 2.103c-1.49.343-2.044 1.691-1.658 3.121l1.77 6.55c.302 1.118 1.484 1.773 2.59 1.464l7.118-1.993c1.102-.308 1.745-1.42 1.462-2.526l-.938-3.678c-.007-.027-.011-.055-.011-.085 0-.053.018-.103.05-.144l.245-.307c.458-.573.617-1.353.461-2.038zm-1.308 5.357c.144.562-.181 1.133-.723 1.285l-7.116 1.994c-.558.156-1.155-.173-1.306-.733l-1.772-6.56c-.145-.533.053-.97.558-1.088l9.113-2.103c.513-.118 1.03.228 1.144.737l.132.667c.078.344-.002.735-.23 1.021l-.244.307c-.156.197-.243.439-.243.693 0 .142.027.28.077.409l.944 3.691zM9.507 19.535c.101.002.203.002.306 0l7.554-1.037a1.031 1.031 0 00.871-1.166l-.004-.03c-.035-.251-.237-.449-.491-.482l-8.08.38c-.303.014-.523.284-.492.587l.024.237c.045.45.39.809.812.911zM4.647 8.043l1.173-.271-.161-.595-1.174.271a.33.33 0 00-.249.404l.02.073c.045.166.216.262.391.218zM3.348 9.172l1.173-.27-.161-.596-1.174.271a.33.33 0 00-.249.404l.02.073c.045.166.216.262.391.218zM2.051 10.3l1.172-.27-.161-.596-1.174.271a.33.33 0 00-.249.404l.02.073c.045.166.216.262.391.218z"/></svg>
                  <span class="text-xs font-bold uppercase tracking-widest">Support Me</span>
                </a>
                
                {/* QR Code Hover Reveal (Desktop Only) */}
                <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-6 p-4 bg-white rounded-3xl shadow-[0_20px_50px_rgba(0,0,0,0.5)] scale-0 group-hover/bmc:scale-100 transition-all duration-300 origin-bottom pointer-events-none hidden md:block z-[100]">
                  <div class="w-40 h-40 bg-slate-100 rounded-2xl overflow-hidden p-2">
                    <img src="/bmc-qr.png" alt="Buy Me A Coffee QR Code" class="w-full h-full object-contain" />
                  </div>
                  <div class="absolute bottom-[-10px] left-1/2 -translate-x-1/2 w-0 h-0 border-l-[10px] border-l-transparent border-r-[10px] border-r-transparent border-t-[10px] border-t-white" aria-hidden="true"></div>
                </div>
              </div>

              <a href="https://music.apple.com/profile/brentzey" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-black/80 backdrop-blur-md border border-[#fa243c]/30 text-white hover:border-[#fa243c] transition-all shadow-[0_0_15px_rgba(250,36,60,0.1)] hover:shadow-[0_0_25px_rgba(250,36,60,0.3)] hover:scale-105 group reveal-on-scroll" style="transition-delay: 200ms" aria-label="Brent Zey's Apple Music Profile">
                <svg class="w-5 h-5 fill-[#fa243c]" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Apple Music</title><path d="M12.115 5.564c-.015-.008-.024-.02-.024-.035V4.321c0-.18-.158-.337-.34-.337l-.023.003c-.23.029-.444.153-.585.34L7.541 9.074c-.114.15-.178.334-.178.523v10.082c0 .181.157.321.334.321h4.093c.184 0 .334-.144.334-.321V9.954l3.188-4.248c.154-.204.148-.48-.02-.676l-.014-.017c-.168-.198-.445-.253-.674-.13L12.115 5.564zm-2.091 14.113c0 .14-.117.255-.256.255H8.3c-.141 0-.256-.115-.256-.255v-9.352c0-.14.115-.255.256-.255h1.468c.139 0 .256.115.256.255v9.352zm3.178-5.32c-.14 0-.255-.115-.255-.255V9.914c0-.14.115-.256.255-.256h1.468c.141 0 .256.116.256.256v4.188c0 .14-.115.255-.256.255h-1.468zm3.253-3.64c-.14 0-.256-.115-.256-.255v-2.02c0-.14.116-.256.256-.256h1.469c.14 0 .255.116.255.256v2.02c0 .14-.115.255-.255.255h-1.469z"/></svg>
                <span class="text-xs font-bold uppercase tracking-widest hidden sm:inline">Apple Music</span>
              </a>
              <a href="https://open.spotify.com/user/1261049078?si=i86wEaEGQnGJOycnCn0pJg" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-black/80 backdrop-blur-md border border-[#1DB954]/30 text-white hover:border-[#1DB954] transition-all shadow-[0_0_15px_rgba(29,185,84,0.1)] hover:shadow-[0_0_25px_rgba(29,185,84,0.3)] hover:scale-105 group reveal-on-scroll" style="transition-delay: 300ms" aria-label="Brent Zey's Spotify Profile">
                <svg class="w-5 h-5 fill-[#1DB954]" role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><title>Spotify</title><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-.1.24-2.82-1.74-6.36-2.1-10.561-1.141-.418.122-.779-.179-.839-.539-.121-.418.179-.779.539-.839 4.5-.961 8.461-.539 11.641 1.5.359.24.48.66.24 1.021zM18.961 14.1c-.3.479-.9.6-1.379.3-3.239-1.979-8.159-2.519-11.939-1.38-.54.18-.1.019-.3.42-.18.54-.779.84-1.319.66-.54-.18-.84-.779-.66-1.319 4.38-1.32 9.78-.719 13.5 1.559.48.3.6.9.3 1.38zM19.08 10.68c-3.9-2.341-10.32-2.521-14.1-1.441a1.2 1.2 0 11-.661-2.34c4.321-1.321 11.401-1.021 15.9 1.681a1.2 1.2 0 01-1.14 2.1z"/></svg>
                <span class="text-xs font-bold uppercase tracking-widest hidden sm:inline">Spotify</span>
              </a>
            </div>
          </div>
        </div>

        <footer class="flex-shrink-0 border-t border-[var(--border-color)] py-12 text-center space-y-6 bg-[var(--nav-bg)] backdrop-blur-md relative z-30 reveal-on-scroll">
          <div class="flex justify-center gap-8 reveal-on-scroll" style="transition-delay: 150ms">
            <a href="https://github.com/brentmzey" target="_blank" rel="noopener noreferrer" class="text-[var(--text-secondary)] hover:text-synth-cyan transition-all hover:scale-110" title="GitHub" aria-label="Brent Zey's GitHub Profile">
              <Github class="w-6 h-6" aria-hidden="true" />
            </a>
            <a href="mailto:brentmzey4795@gmail.com" class="text-[var(--text-secondary)] hover:text-synth-pink transition-all hover:scale-110" title="Email" aria-label="Email Brent Zey">
              <Mail class="w-6 h-6" aria-hidden="true" />
            </a>
          </div>
          <p class="text-[var(--text-secondary)] text-sm font-medium tracking-wide pb-24 md:pb-8 reveal-on-scroll" style="transition-delay: 250ms">© 2026 Brent Zey. All rights reserved.</p>
          <div class="text-[var(--text-secondary)] text-[10px] opacity-40 uppercase tracking-widest reveal-on-scroll" style="transition-delay: 350ms">
            Logos by <a href="https://simpleicons.org" target="_blank" rel="noopener noreferrer" class="hover:text-synth-cyan transition-colors">Simple Icons</a>
          </div>
        </footer>
      </div>
    </div>


    <script is:inline>
      const setupToggle = (id, theme) => {
        document.getElementById(id)?.addEventListener('click', () => {
          localStorage.setItem('theme', theme);
          applyTheme(theme);
        });
      };

      // Desktop
      setupToggle('modeLight', 'light');
      setupToggle('modeSystem', 'system');
      setupToggle('modeDark', 'dark');

      // Mobile
      setupToggle('modeLightMobile', 'light');
      setupToggle('modeSystemMobile', 'system');
      setupToggle('modeDarkMobile', 'dark');

      // Scroll Reveal Observer
      const initScrollReveal = () => {
        const isMobile = window.innerWidth < 768;
        const scrollRoot = isMobile ? null : document.querySelector('.parallax-container');
        
        const observerOptions = {
          root: scrollRoot,
          threshold: 0.15,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));
      };

      // Mobile Nav Smart Flow Logic
      const initMobileNav = () => {
        const mobileNav = document.getElementById('mobile-nav');
        if (!mobileNav) return;

        const isMobile = window.innerWidth < 768;
        const scrollTarget = isMobile ? window : document.querySelector('.parallax-container');
        if (!scrollTarget) return;

        let lastScrollTop = 0;

        const handleScroll = () => {
          const scrollTop = isMobile ? window.scrollY : (scrollTarget.scrollTop || 0);
          
          if (scrollTop > lastScrollTop && scrollTop > 20) {
            mobileNav.style.opacity = '0.7';
            mobileNav.style.transform = 'translateY(-12px) scale(0.96)';
          } else {
            mobileNav.style.opacity = '1';
            mobileNav.style.transform = 'translateY(-12px) scale(1)';
          }
          lastScrollTop = scrollTop;
        };

        scrollTarget.addEventListener('scroll', handleScroll, { passive: true });
        
        // Initial state: Floating above the bottom
        mobileNav.style.transform = 'translateY(-12px)';
      };

      // Initial UI Sync
      window.addEventListener('DOMContentLoaded', () => {
        applyTheme(getTheme());
        initScrollReveal();
        initMobileNav();
      });
    </script>
  </body>
</html>
